# --- LeafBridge secrets & local state (NEVER commit) ---
# NOTE: git does NOT support inline "# ..." comments after a pattern, so every
# pattern below is on its own line. projects.json holds your Overleaf project
# links and git tokens; keep it out of the repo.
projects.json
projects.local.json
.env
*.token

# git clone cache (disposable; may also live under %LOCALAPPDATA%)
.cache/
data/

# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
